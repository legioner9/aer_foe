#!/bin/bash

# read -p "see IFS"

idir_42434515=$(pwd)

if [ -f ~/.bash_aliases ]; then

    . ~/.bash_aliases

fi

#* file example inner text for ~/.bashrc  --------- START INNER ------------

parse_lib_conf_fn() {

    [ -f ${HOME}/.bashrc.lib.conf ] || {

        #* default .bashrc.lib.conf:
        echo -e "#!/bin/bash

[ -n \"\${STL_REPO_PATH}\" ] || readonly STL_REPO_PATH=\${HOME}/REPOBARE/_repo/stl
[ -n \"\${STL_D_PATH}\" ] || readonly STL_D_PATH=\${HOME}/REPOBARE/_repo/stl/.d/.stl.d
[ -n \"\${STL_DATA_D_PATH}\" ] || readonly STL_DATA_D_PATH=\${HOME}/REPOBARE/_repo/stl/.d/.stl.data.d
[ -n \"\${STL_LIB_D_PATH}\" ] || readonly STL_LIB_D_PATH=\${HOME}/REPOBARE/_repo/stl/.d/.stl.lib.d

export STL_D_PATH STL_DATA_D_PATH STL_LIB_D_PATH
" >"${HOME}"/.bashrc.lib.conf
    }
    . ${HOME}/.bashrc.lib.conf

    [ -d "${STL_REPO_PATH}" ] || {
        echo "\${STL_REPO_PATH}=${STL_REPO_PATH} NOT_DIR : check file://${HOME}/.bashrc.lib.conf" >&2
    }

    [ -d "${STL_D_PATH}" ] || {
        echo "\${STL_D_PATH}=${STL_D_PATH} NOT_DIR : check file://${HOME}/.bashrc.lib.conf" >&2
    }

    [ -d "${STL_DATA_D_PATH}" ] || {
        echo "\${STL_DATA_D_PATH}=${STL_DATA_D_PATH} NOT_DIR : check file://${HOME}/.bashrc.lib.conf" >&2
    }

    [ -d "${STL_LIB_D_PATH}" ] || {
        echo "\${STL_D_PATH}=${STL_LIB_D_PATH} NOT_DIR : check file://${HOME}/.bashrc.lib.conf" >&2
    }

    return 0

}

#? SATRT parse_lib_conf_fn : UpMem const (pathes) for STL from ${HOME}/.bashrc.lib.conf
parse_lib_conf_fn

unset IFS

bashrc_version_1() {

    if [[ -f ${HOME}/.d/.rc.d/.st.rc.d/.st.rc ]]; then if ! . ${HOME}/.d/.rc.d/.st.rc.d/.st.rc &>${HOME}/.strc.log; then
        # if [[ -f ~/.d/.rc.d/.st.rc.d/.st.rc ]]; then if ! . ~/.d/.rc.d/.st.rc.d/.st.rc >/dev/null; then
        echo -e "in ${HOME}/.bashrc : FAIL . ${HOME}/.d/.rc.d/.st.rc.d/.st.rc
    see file://${HOME}/.strc.log :
    'cat ${HOME}/.strc.log'
    remove this lib : 
    'echo 0 > ${HOME}/.strc.use.flag' 
    " >&2
    fi; fi

    #! entry point to boot stl

    if [ -f ${STL_D_PATH}/.stldrc ]; then if ! . ${STL_D_PATH}/.stldrc &>${HOME}/.stldrc.log; then
        echo -e "in ${HOME}/.bashrc : FAIL . ${STL_D_PATH}/.stldrc
    see file://${HOME}/.stldrc.log :
    'cat ${HOME}/.stldrc.log'
    remove this lib :
    'echo 0 > ${HOME}/.stldrc.use.flag'
    " >&2
    fi; fi

}

#? SATRT bashrc version_1
bashrc_version_1

unset IFS

fn_csdaw4343tf(){

    fn_nm=$HOME/aer_foe/.d/.repo.d/.repo.rc

    [[ -f ${fn_nm} ]] && {
        . "${fn_nm}" > $HOME/null || {
            echo -e "in file://${fn_nm} , line=${LINENO} :: EXEC : '. ${fn_nm}', 'RESUME :: aer_foe .repo.rc FAIL' return 1${NRM}" >&2
            return 1
        }
    }
}
fn_csdaw4343tf @

cd "${idir_42434515}" || echo "FAIL_EXEC: cd ${idir_42434515}"




